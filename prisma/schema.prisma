generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Shopify SDK Session Storage ─────────────────────────────────────────────
// Exact shape required by @shopify/shopify-app-session-storage-prisma
model Session {
  id            String    @id
  shop          String
  state         String?
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String    @db.Text
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)

  @@index([shop])
}

// ─── ShopSamp Store Registry ──────────────────────────────────────────────────
model ShopifyStore {
  id            String    @id @default(cuid())
  shopDomain    String    @unique   // e.g. my-store.myshopify.com
  shopName      String
  installedAt   DateTime  @default(now())
  uninstalledAt DateTime?
  isActive      Boolean   @default(true)
  planTier      String    @default("free")
  updatedAt     DateTime  @updatedAt

  products      ShopifyProduct[]
}

// ─── Generated Products ───────────────────────────────────────────────────────
model ShopifyProduct {
  id               String       @id @default(cuid())
  shopDomain       String
  store            ShopifyStore @relation(fields: [shopDomain], references: [shopDomain], onDelete: Cascade)

  shopifyProductId String       // Shopify's GID or numeric ID
  title            String
  isDraft          Boolean      @default(true)
  sourceData       Json         // Full generated product payload

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([shopDomain, shopifyProductId])
  @@index([shopDomain])
}
