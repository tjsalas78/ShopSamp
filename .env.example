# ─── Database (Neon PostgreSQL) ────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Shopify App ──────────────────────────────────────────
# From Shopify Partner Dashboard → Apps → [Your App] → API credentials
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SHOPIFY_SCOPES="write_products,read_products,write_inventory,read_inventory"
# Your deployed app URL (no trailing slash)
SHOPIFY_APP_URL="https://shopsamp.vercel.app"

# ─── Expose API key to browser for App Bridge ─────────────
NEXT_PUBLIC_SHOPIFY_API_KEY=""   # same value as SHOPIFY_API_KEY

# ─── Anthropic Claude AI ──────────────────────────────────
ANTHROPIC_API_KEY=""

# ─── Token Encryption ────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# ─── Vercel Blob (image storage) ──────────────────────────
BLOB_READ_WRITE_TOKEN=""
